# Docker Environment Variables
# Copy this file to .env for Docker deployments
#
# REQUIRED for production: Copy this file to .env and fill in real values.
# Run: cp .env.docker.example .env
# Then generate secure secrets with: openssl rand -base64 32

# MongoDB Credentials (REQUIRED for production)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your-secure-password-here

# JWT Secrets (REQUIRED for production - must be set before running docker-compose.yml)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:80,http://localhost:5173
